# Syntax Telegram Bot - Environment Variables

# ============================================
# TELEGRAM BOT TOKEN (REQUIRED)
# ============================================
# Get from @BotFather in Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ============================================
# AI PROVIDERS (at least one required)
# ============================================

# OpenAI (GPT-4o, GPT-4o-mini, etc.)
OPENAI_API_KEY=sk-your-openai-key

# Anthropic (Claude 3.5 Sonnet, Claude 3 Opus)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Google Gemini
GEMINI_API_KEY=your-google-gemini-key

# ============================================
# OPTIONAL: Image Generation (coming soon)
# ============================================

# OpenAI DALL-E
# DALLE_API_KEY=your-dalle-key

# Replicate (for Flux, Midjourney, etc.)
# REPLICATE_API_KEY=your-replicate-key

# ============================================
# OPTIONAL: Voice (coming soon)
# ============================================

# ElevenLabs (voice cloning, TTS)
# ELEVENLABS_API_KEY=your-elevenlabs-key

# ============================================
# OPTIONAL: Video (coming soon)
# ============================================

# Runway ML
# RUNWAY_API_KEY=your-runway-key

# Kling AI
# KLING_API_KEY=your-kling-key

# ============================================
# PAYMENT (WATA - coming soon)
# ============================================

# WATA Payment API
# WATA_API_KEY=your-wata-key
